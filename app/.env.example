# =====================================================================
# Overlap — Expo environment example
# =====================================================================
# Copy this file to one of:
#   .env              (shared local defaults, ignored by git)
#   .env.development  (local dev overrides)
#   .env.staging      (staging overrides)
#   .env.production   (production overrides)
#
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the React
# Native / Expo runtime (see https://docs.expo.dev/guides/environment-variables/).
# Never put service_role keys or any server-only secrets in here — they
# would be shipped inside the bundle.
# =====================================================================

# Which environment this build represents. Used for logging, feature
# flags, and selecting repository implementations.
# One of: development | staging | production
EXPO_PUBLIC_ENV=development

# Supabase project URL (public, safe to ship with the client).
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon key (public, safe to ship with the client).
# Do NOT put the service_role key here — that belongs only on a
# server / edge function.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Force the repository layer to use the local mock implementations even
# when Supabase credentials are present. Useful for offline dev and
# for UI work that shouldn't hit the real backend.
# One of: true | false
EXPO_PUBLIC_USE_LOCAL_REPOSITORIES=true
